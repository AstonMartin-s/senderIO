{
  "name": "senderio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Orquestador de goteo de plantillas WhatsApp sobre Kommo (reemplazo de n8n).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "start:api": "node --import tsx src/api/index.ts",
    "start:worker": "node --import tsx src/worker/index.ts",
    "start:api:prod": "npm run db:migrate && node --import tsx src/api/index.ts",
    "build:dashboard": "cd dashboard && npm ci && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:clean": "tsx src/db/clean.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "node-cron": "^4.4.1",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
