# === Base de datos (Postgres) ===
# Local (Homebrew PostgreSQL 16): el usuario por defecto es tu usuario de macOS.
DATABASE_URL=postgresql://localhost:5432/senderio

# === Kommo ===
# Subdominio de tu cuenta (https://<subdominio>.kommo.com)
KOMMO_SUBDOMAIN=mooneyatkinson
# Token long-lived de una integración privada de Kommo (Authorization: Bearer <token>)
KOMMO_TOKEN=
# Secreto opcional para validar el webhook entrante
KOMMO_WEBHOOK_SECRET=
# Modo de cliente Kommo: "real" pega contra la API, "mock" simula leads en memoria
KOMMO_MODE=mock

# === API ===
API_PORT=3000
# Contraseña simple para proteger los endpoints de control del panel (futuro)
ADMIN_PASSWORD=changeme

# === Zona horaria de la operación ===
TZ=America/Argentina/Cordoba

# === Programa Trazabilidad (push automático de envíos) ===
TRAZABILIDAD_API_URL=http://127.0.0.1:8000
TRAZABILIDAD_INGEST_API_KEY=
TRAZABILIDAD_PUSH_ENABLED=false
